# Network interface connected to the FLIR camera switch
NETWORK_INTERFACE=enp4s0

# Base URL for the React frontend (usually localhost)
REACT_APP_BASE_URL=localhost

# Directory on the host where recordings are saved
# Recommend ext4 filesystem (not NTFS) for best performance
DATA_VOLUME=/home/cameras/data

# Directory containing camera config YAML files (e.g. camera_config.yaml)
CAMERA_CONFIGS=/home/cameras/configs

# DataJoint external storage mount (optional, for analysis pipeline)
DATAJOINT_EXTERNAL=/mnt/datajoint_external
